GOOGLE_CLOUD_PROJECT=your-agent-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
MODEL=gemini-3.5-flash
AGENT_URL=http://127.0.0.1:8000

BRIDGE_BIGQUERY_TABLE=YOUR_PROJECT_ID.bridge_inventory.bridge_data
BIGQUERY_JOB_PROJECT=your-agent-project-id
# Set only when the dataset is not in its default BigQuery location.
BIGQUERY_LOCATION=

GOOGLE_MAPS_API_KEY=your-maps-embed-api-key
