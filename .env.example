GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# ADK/Gemini model used by the agent.
AGENT_MODEL=gemini-2.0-flash

# Public Cloud Run URL after deployment, for example:
# https://enterprise-data-a2a-agent-abc123-uc.a.run.app
# Leave empty for local development.
A2A_PUBLIC_URL=

# Comma-separated BigQuery table ids. Configure five tables here.
# Supported formats:
#   project.dataset.table
#   dataset.table            (uses GOOGLE_CLOUD_PROJECT)
BIGQUERY_TABLES=YOUR_PROJECT_ID.bridge_inventory.bridge,YOUR_PROJECT_ID.bridge_inventory.crash,YOUR_PROJECT_ID.bridge_inventory.eilis,YOUR_PROJECT_ID.bridge_inventory.road,YOUR_PROJECT_ID.bridge_inventory.traffic

# Optional comma-separated aliases matching BIGQUERY_TABLES.
BIGQUERY_TABLE_ALIASES=bridge,crash,eilis,road,traffic

# Cost and response controls for generated SQL.
BIGQUERY_MAX_BYTES_BILLED=1000000000
BIGQUERY_DEFAULT_LIMIT=100
BIGQUERY_MAX_LIMIT=1000

# Google Cloud Storage source.
GCS_BUCKET_NAME=YOUR_BUCKET_NAME
GCS_PREFIX=
GCS_MAX_TEXT_BYTES=200000
GCS_MAX_PDF_BYTES=25000000
GCS_MAX_PDF_PAGES=20
GCS_MAX_PDF_TEXT_CHARS=60000

# Cloud Run listens on PORT; 8080 is the local default.
PORT=8080

# Orchestrator/router deployment settings. The router is a separate Cloud Run
# service that forwards A2A requests to the specialist agents below.
ROUTER_NAME=Transportation Orchestrator Agent
ROUTER_PUBLIC_URL=
DATA_AGENT_URL=https://YOUR-DATA-AGENT-URL.run.app
MAP_AGENT_URL=https://YOUR-MAP-AGENT-URL
ROUTER_DEFAULT_AGENT=data
ROUTER_REQUEST_TIMEOUT_SECONDS=120
ROUTER_USE_ID_TOKEN=true
